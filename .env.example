# WebSocket URL for the sync server (required if frontend is NOT on the same host)
# Example Render sync-only service:
# VITE_WS_URL=wss://league-planning-sync.onrender.com

# Local dev: leave unset — client uses ws://localhost:3001
# Render full Docker: leave unset — client uses same host (wss://your-app.onrender.com)

# MongoDB Atlas — producción (Render Environment)
# Opción A (recomendada en Render):
# MONGODB_USER=league_planning
# MONGODB_PASSWORD=tu_password
# MONGODB_HOST=cluster0.ukwu6uu.mongodb.net
# MONGODB_DB=league_planning
#
# Opción B: URI completa
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.ukwu6uu.mongodb.net/?appName=Cluster0
#
# Atlas → Network Access: 0.0.0.0/0 (ver render.com/docs/connect-to-mongodb-atlas)
#
# Local: edita local/.env y ejecuta npm run test:mongo
